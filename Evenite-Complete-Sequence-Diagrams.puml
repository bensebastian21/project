@startuml
title Evenite Complete Sequence Diagrams

skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 12

' Sequence Diagram 1: User Registration
actor User
participant "Frontend" as FE
participant "Auth Service" as Auth
participant "Database" as DB

User -> FE: Enter registration details
FE -> Auth: Validate input
Auth -> Auth: Hash password
Auth -> DB: Save user data
DB --> Auth: Confirmation
Auth --> FE: Registration success
FE -> User: Display success message
FE -> User: Redirect to login

' Sequence Diagram 2: User Login
actor "Student/Host/Admin" as UserRole
UserRole -> FE: Enter login credentials
FE -> Auth: Validate credentials
Auth -> DB: Check user data
DB --> Auth: Return user data
Auth -> Auth: Generate JWT token
Auth --> FE: Login success with token
FE -> UserRole: Redirect to dashboard

' Sequence Diagram 3: Event Registration
actor Student
participant "Frontend" as FE2
participant "Event Service" as EventS
participant "Database" as DB2
participant "Notification Service" as Notif

Student -> FE2: Browse events
FE2 -> EventS: Request events
EventS -> DB2: Fetch events
DB2 --> EventS: Return events
EventS --> FE2: Display events
FE2 -> Student: Show events

Student -> FE2: Select event
FE2 -> EventS: Check capacity
EventS -> DB2: Get registration count
DB2 --> EventS: Return count
EventS --> FE2: Confirm availability
FE2 -> Student: Show registration form

Student -> FE2: Submit registration
FE2 -> EventS: Process registration
EventS -> DB2: Save registration
DB2 --> EventS: Confirmation
EventS -> Notif: Send confirmation
Notif -> Student: Notification
EventS --> FE2: Registration success
FE2 -> Student: Display confirmation

' Sequence Diagram 4: Event Creation
actor Host
participant "Frontend" as FE3
participant "Event Service" as EventS2
participant "Database" as DB3

Host -> FE3: Access event creation form
FE3 -> Host: Display form
Host -> FE3: Fill event details
FE3 -> EventS2: Validate and submit
EventS2 -> DB3: Save event data
DB3 --> EventS2: Confirmation
EventS2 --> FE3: Event created
FE3 -> Host: Show success message

' Sequence Diagram 5: User Profile Management
actor "Any User" as AnyUser
participant "Frontend" as FE4
participant "User Service" as UserS
participant "Database" as DB4

AnyUser -> FE4: Access profile page
FE4 -> UserS: Request user data
UserS -> DB4: Fetch user data
DB4 --> UserS: Return user data
UserS --> FE4: Send user data
FE4 -> AnyUser: Display profile

AnyUser -> FE4: Update profile information
FE4 -> UserS: Send updated data
UserS -> DB4: Update user data
DB4 --> UserS: Confirmation
UserS --> FE4: Update success
FE4 -> AnyUser: Show confirmation

' Sequence Diagram 6: Event Feedback Submission
actor Student2
participant "Frontend" as FE5
participant "Feedback Service" as FeedS
participant "Database" as DB5

Student2 -> FE5: Access event feedback form
FE5 -> FeedS: Request event details
FeedS -> DB5: Fetch event data
DB5 --> FeedS: Return event data
FeedS --> FE5: Send event info
FE5 -> Student2: Display feedback form

Student2 -> FE5: Submit feedback and rating
FE5 -> FeedS: Process feedback
FeedS -> DB5: Save feedback
DB5 --> FeedS: Confirmation
FeedS --> FE5: Feedback saved
FE5 -> Student2: Show confirmation

' Sequence Diagram 7: Certificate Generation
actor Host2
participant "Frontend" as FE6
participant "Certificate Service" as CertS
participant "Database" as DB6
participant "Storage Service" as Storage

Host2 -> FE6: Initiate certificate generation
FE6 -> CertS: Request certificates
CertS -> DB6: Fetch event and registrants
DB6 --> CertS: Return data
CertS -> CertS: Generate certificates
CertS -> Storage: Save certificates
Storage --> CertS: Confirmation
CertS --> FE6: Certificates generated
FE6 -> Host2: Show success message
CertS -> DB6: Update certificate status
@enduml