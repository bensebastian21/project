@startuml
' Use Case Diagram
left to right direction
skinparam packageStyle rectangle
actor "Student" as student
actor "Host" as host
actor "Administrator" as admin

rectangle "Evenite System" {
  student -- (Browse Events)
  student -- (Register for Event)
  student -- (View Registration Status)
  student -- (Provide Feedback)
  student -- (Collect Certificate)
  student -- (Manage Profile)
  student -- (Connect with Peers)
  
  host -- (Create Event)
  host -- (Manage Event)
  host -- (Track Registrations)
  host -- (Generate Certificate)
  host -- (View Analytics)
  host -- (Manage Profile)
  
  admin -- (Manage Users)
  admin -- (Verify Students)
  admin -- (Monitor System)
  admin -- (Generate Reports)
  admin -- (Manage Content)
  admin -- (Configure System)
  
  (Browse Events) .> (Search Events) : extends
  (Browse Events) .> (Filter Events) : extends
  (Register for Event) .> (Cancel Registration) : extends
  (Manage Event) .> (Update Event) : extends
  (Manage Event) .> (Delete Event) : extends
  (Manage Event) .> (Publish Event) : extends
}
@enduml

@startuml
' Class Diagram
class User {
  -userId: String
  -username: String
  -email: String
  -password: String
  -role: String
  -profilePic: String
  -createdAt: Date
  -updatedAt: Date
  +login()
  +logout()
  +updateProfile()
}

class Student {
  -studentId: String
  -institute: String
  -phone: String
  -isVerified: Boolean
  +registerForEvent()
  +provideFeedback()
  +collectCertificate()
}

class Host {
  -hostId: String
  -organization: String
  -contactInfo: String
  +createEvent()
  +manageEvent()
  +trackRegistrations()
}

class Administrator {
  -adminId: String
  -permissions: String[]
  +manageUsers()
  +verifyStudents()
  +monitorSystem()
}

class Event {
  -eventId: String
  -title: String
  -description: String
  -date: Date
  -location: String
  -capacity: Integer
  -status: String
  +create()
  +update()
  +delete()
  +publish()
}

class Registration {
  -registrationId: String
  -status: String
  -registeredAt: Date
  -attended: Boolean
  +confirm()
  +cancel()
}

class Feedback {
  -feedbackId: String
  -rating: Integer
  -comment: String
  -submittedAt: Date
  +submit()
}

class Certificate {
  -certificateId: String
  -issuedAt: Date
  -expiresAt: Date
  -certificateUrl: String
  +generate()
  +revoke()
}

class Notification {
  -notificationId: String
  -message: String
  -timestamp: Date
  -isRead: Boolean
  +send()
  +markAsRead()
}

' Relationships
User <|-- Student
User <|-- Host
User <|-- Administrator

Student "1" -- "0..*" Registration
Host "1" -- "0..*" Event
Event "1" -- "0..*" Registration
Event "1" -- "0..*" Feedback
Event "1" -- "0..*" Certificate

Registration "0..*" -- "1" Event
Registration "0..*" -- "1" Student
Feedback "0..*" -- "1" Event
Feedback "0..*" -- "1" Student
Certificate "0..*" -- "1" Event
Certificate "0..*" -- "1" Student

User "1" -- "0..*" Notification
Event "1" -- "0..*" Notification
@enduml

@startuml
' Sequence Diagram - User Registration
actor User
participant "Frontend" as FE
participant "Auth Service" as Auth
participant "Database" as DB

User -> FE: Enter registration details
FE -> Auth: Validate input
Auth -> Auth: Hash password
Auth -> DB: Save user data
DB --> Auth: Confirmation
Auth --> FE: Registration success
FE -> User: Display success message
FE -> User: Redirect to login
@enduml

@startuml
' Sequence Diagram - Event Registration
actor Student
participant "Frontend" as FE
participant "Event Service" as EventS
participant "Database" as DB
participant "Notification Service" as Notif

Student -> FE: Browse events
FE -> EventS: Request events
EventS -> DB: Fetch events
DB --> EventS: Return events
EventS --> FE: Display events
FE -> Student: Show events

Student -> FE: Select event
FE -> EventS: Check capacity
EventS -> DB: Get registration count
DB --> EventS: Return count
EventS --> FE: Confirm availability
FE -> Student: Show registration form

Student -> FE: Submit registration
FE -> EventS: Process registration
EventS -> DB: Save registration
DB --> EventS: Confirmation
EventS -> Notif: Send confirmation
Notif -> Student: Notification
EventS --> FE: Registration success
FE -> Student: Display confirmation
@enduml

@startuml
' Object Diagram
object "student1: Student" as s1 {
  userId = "S001"
  username = "john_doe"
  email = "john@example.com"
  role = "student"
}

object "host1: Host" as h1 {
  userId = "H001"
  username = "tech_fest_org"
  email = "contact@techfest.com"
  role = "host"
}

object "event1: Event" as e1 {
  eventId = "E001"
  title = "Tech Fest 2025"
  date = "2025-12-15"
  location = "Main Auditorium"
  capacity = 200
}

object "registration1: Registration" as r1 {
  registrationId = "R001"
  status = "confirmed"
  attended = false
}

object "feedback1: Feedback" as f1 {
  feedbackId = "F001"
  rating = 5
  comment = "Great event!"
}

s1 --> r1
h1 --> e1
e1 --> r1
r1 --> f1
@enduml

@startuml
' Component Diagram
package "Frontend" {
  [React App] as frontend
  [Authentication Module] as authModule
  [Event Management Module] as eventModule
  [User Profile Module] as profileModule
  [Notification Module] as notifModule
}

package "Backend" {
  [API Gateway] as apiGateway
  [Auth Service] as authService
  [Event Service] as eventService
  [User Service] as userService
  [Notification Service] as notifService
  [Database Adapter] as dbAdapter
}

package "Database" {
  [MongoDB] as database
}

package "External Services" {
  [Cloudinary] as cloudinary
  [Email Service] as emailService
}

frontend --> apiGateway : HTTP/HTTPS
authModule --> authService
eventModule --> eventService
profileModule --> userService
notifModule --> notifService

apiGateway --> authService : REST API
apiGateway --> eventService : REST API
apiGateway --> userService : REST API
apiGateway --> notifService : REST API

authService --> dbAdapter
eventService --> dbAdapter
userService --> dbAdapter
notifService --> dbAdapter
dbAdapter --> database

eventService --> cloudinary : Image Storage
notifService --> emailService : Send Emails
@enduml

@startuml
' Deployment Diagram
node "Client Devices" {
  node "Browser" {
    [Web Application] as webapp
  }
}

node "Vercel Cloud" {
  node "Frontend Server" {
    [React Frontend] as frontend
  }
  
  node "Backend Server" {
    [Node.js API] as backend
  }
}

node "Database Server" {
  [MongoDB Atlas] as database
}

node "Cloud Storage" {
  [Cloudinary] as storage
}

node "Email Service" {
  [SMTP Server] as email
}

webapp --> frontend : HTTPS
frontend --> backend : HTTPS
backend --> database : MongoDB Wire Protocol
backend --> storage : HTTPS
backend --> email : SMTP
@enduml

@startuml
' State Chart Diagram - User Authentication
[*] --> LoggedOut
LoggedOut --> LoggingIn : submit credentials
LoggingIn --> Authenticated : valid credentials
LoggingIn --> Error : invalid credentials
Error --> LoggingIn : retry
Authenticated --> LoggedOut : logout
Authenticated --> Active : continue session
Active --> Authenticated : session timeout
Active --> LoggedOut : logout

state LoggingIn {
  [*] --> ValidatingInput
  ValidatingInput --> CheckingCredentials : input valid
  CheckingCredentials --> AuthSuccess : credentials valid
  CheckingCredentials --> AuthFailure : credentials invalid
  AuthSuccess --> [*]
  AuthFailure --> [*]
}
@enduml

@startuml
' State Chart Diagram - Event Lifecycle
[*] --> Draft
Draft --> Published : publish event
Draft --> Cancelled : cancel event
Published --> RegistrationOpen : open registration
RegistrationOpen --> RegistrationClosed : close registration
RegistrationClosed --> InProgress : event starts
InProgress --> Completed : event ends
Completed --> CertificateGeneration : generate certificates
CertificateGeneration --> FeedbackCollection : collect feedback
FeedbackCollection --> Archived : archive event
Cancelled --> [*]
Archived --> [*]

Draft : Event created
Published : Event visible to users
RegistrationOpen : Users can register
RegistrationClosed : Registration deadline passed
InProgress : Event is happening
Completed : Event finished
CertificateGeneration : Creating certificates
FeedbackCollection : Collecting feedback
Archived : Event archived
Cancelled : Event cancelled
@enduml

@startuml
' Activity Diagram - Event Registration Process
[*] --> Start
Start --> BrowseEvents
BrowseEvents --> SelectEvent : Event chosen
SelectEvent --> CheckAvailability : Check if event has capacity
CheckAvailability --> RegistrationForm : Event has capacity
CheckAvailability --> EventFull : Event is full
EventFull --> BrowseEvents : Choose another event
RegistrationForm --> FillDetails : Enter personal info
FillDetails --> SubmitRegistration : Submit form
SubmitRegistration --> ValidateInput : Validate data
ValidateInput --> SaveRegistration : Data valid
ValidateInput --> ShowErrors : Data invalid
ShowErrors --> FillDetails : Correct errors
SaveRegistration --> SendConfirmation : Save to database
SendConfirmation --> SendNotification : Notify user
SendNotification --> RegistrationComplete
RegistrationComplete --> [*]

note right of CheckAvailability
  System checks if event
  has available capacity
end note

note right of ValidateInput
  System validates all
  required fields and
  data formats
end note
@enduml

@startuml
' Activity Diagram - Event Creation Process
[*] --> Start
Start --> LoginAsHost
LoginAsHost --> AccessDashboard : Successful login
AccessDashboard --> CreateEvent : Click create event
CreateEvent --> EventForm : Display form
EventForm --> FillEventDetails : Enter event info
FillEventDetails --> ValidateDetails : Submit form
ValidateDetails --> SaveEvent : Details valid
ValidateDetails --> ShowErrors : Details invalid
ShowErrors --> FillEventDetails : Correct errors
SaveEvent --> UploadMedia : Save to database
UploadMedia --> ProcessUpload : Upload images
ProcessUpload --> PublishEvent : Media processed
PublishEvent --> NotifyFollowers : Send notifications
NotifyFollowers --> EventPublished : Complete
EventPublished --> [*]

note right of ValidateDetails
  System validates all
  required fields, dates,
  capacity, and formats
end note

note right of UploadMedia
  Host can upload event
  images and documents
end note
@enduml