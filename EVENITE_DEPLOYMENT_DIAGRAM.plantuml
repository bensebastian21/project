@startuml
' Deployment Diagram for Evenite System
title Evenite: Event Management System - Deployment Diagram
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 12

node "Client Devices" {
  node "Browser" {
    [Web Application] as webapp
  }
}

node "Vercel Cloud" {
  node "Frontend Server" {
    [React Frontend] as frontend
  }
  
  node "Backend Server" {
    [Node.js API] as backend
  }
}

node "Database Server" {
  [MongoDB Atlas] as database
}

node "Cloud Storage" {
  [Cloudinary] as storage
}

node "Email Service" {
  [SMTP Server] as email
}

webapp --> frontend : HTTPS
frontend --> backend : HTTPS
backend --> database : MongoDB Wire Protocol
backend --> storage : HTTPS
backend --> email : SMTP
@enduml